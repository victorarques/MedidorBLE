<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/selectableItemBackground">
    <TextView android:id="@+id/tvProjectName"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="18sp" android:textStyle="bold" android:text="Projecte"/>
    <TextView android:id="@+id/tvProjectInfo"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="13sp" android:textColor="#666" android:text="0 habitacions"/>
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#E0E0E0" android:layout_marginTop="8dp"/>
</LinearLayout>
