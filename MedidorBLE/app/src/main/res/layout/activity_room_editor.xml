<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="8dp"
        android:background="#E3F2FD" android:gravity="center_vertical">
        <Button android:id="@+id/btnScan"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Cercar Làser BLE"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <TextView android:id="@+id/tvBleStatus"
            android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
            android:layout_marginStart="8dp" android:text="Desconnectat"
            android:textColor="@color/red" android:textSize="13sp"/>
    </LinearLayout>

    <com.medidorble.ui.FloorPlanView
        android:id="@+id/floorPlanView"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:background="#FAFAFA"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="8dp">

        <TextView android:id="@+id/tvMeasurement"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="&#8212; esperant mesura &#8212;"
            android:textSize="26sp" android:textStyle="bold"
            android:gravity="center" android:textColor="#1565C0" android:padding="6dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gir:" android:layout_marginEnd="4dp"/>
            <SeekBar
                android:id="@+id/sliderAngle"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:max="54"
                android:progress="18"/>
            <TextView android:id="@+id/tvAngleValue"
                android:layout_width="44dp" android:layout_height="wrap_content"
                android:text="90°" android:gravity="end"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btnNewRoom"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:text="+ Habitació" android:layout_margin="3dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <Button android:id="@+id/btnManualInput"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:text="Manual" android:layout_margin="3dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <Button android:id="@+id/btnAddWall"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:text="+ Paret" android:layout_margin="3dp"
                android:enabled="false"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btnUndo"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:text="↩ Desfer" android:layout_margin="3dp"
                android:enabled="false"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <Button android:id="@+id/btnCloseRoom"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:text="✓ Tancar" android:layout_margin="3dp"
                android:enabled="false"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btnExportDxf"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:text="⬆ DXF" android:layout_margin="3dp"
                android:enabled="false"/>
            <Button android:id="@+id/btnExportXlsx"
                android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:text="⬆ Excel" android:layout_margin="3dp"
                android:enabled="false"/>
        </LinearLayout>

        <TextView android:id="@+id/tvWallList"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:fontFamily="monospace" android:textSize="12sp"
            android:padding="6dp" android:textColor="#333"
            android:background="#F5F5F5" android:layout_marginTop="4dp"/>

    </LinearLayout>
    </ScrollView>
</LinearLayout>
